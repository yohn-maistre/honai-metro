# ETNOS frontend configuration. Copy to `.env` and edit.
# All PUBLIC_* vars are exposed to the browser.

# --- Backend instance ---
# The PieFed/Lemmy instance the frontend talks to.
# Default: PieFed flagship. Falls back to lemmy.ml if the alpha adapter has issues.
PUBLIC_INSTANCE_URL=piefed.social
# "lemmyv3" for Lemmy backends, "piefedalpha" for PieFed.
PUBLIC_INSTANCE_TYPE=piefedalpha
# Optional: separate internal hostname for SSR fetches (server-side only).
# PUBLIC_INTERNAL_INSTANCE=piefed.social
# Lock the UI to PUBLIC_INSTANCE_URL (hides instance selector). Recommended for ETNOS deployments.
PUBLIC_LOCK_TO_INSTANCE=true

# --- Locale ---
# ETNOS default: Indonesian. Other supported: "en", "pmy" (Melayu Papua).
PUBLIC_LANGUAGE=id

# --- Rendering ---
# Server-side rendering. Off by default (CF Pages static + client hydrate).
PUBLIC_SSR_ENABLED=false

# --- Branding ---
# Hide the upstream xyphyn/photon footer links (donate, source).
PUBLIC_XYLIGHT_MODE=false

# --- Theme override (optional) ---
# JSON theme object — omit to use the Honai Metro default.
# PUBLIC_THEME=

# --- Fallback dev backend (uncomment to switch to Lemmy if PieFed alpha misbehaves) ---
# PUBLIC_INSTANCE_URL=lemmy.ml
# PUBLIC_INSTANCE_TYPE=lemmyv3

# --- Feed defaults ---
# Default listing for feeds/community lists. "Local" keeps ETNOS content
# front and center; "All" shows the whole federated universe.
PUBLIC_DEFAULT_FEED=Local

# --- News (KILAS ticker) ---
# Base URL of the detak-detik worker; its hourly /ticker feed (RSS headlines,
# {src, teks, url}[]) flips the KILAS strip from CONTOH to LANGSUNG.
# Leave unset to keep the honestly-labeled baked sample.
# PUBLIC_DETAK_URL=
